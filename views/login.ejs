<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Pelanggan | Portal ISP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root {
      --auth-surface: rgba(255, 255, 255, 0.9);
      --auth-border: rgba(15, 76, 255, 0.2);
      --auth-shadow: 0 30px 60px rgba(15, 23, 42, 0.2);
      --auth-highlight: rgba(255, 255, 255, 0.35);
      --auth-text-soft: #526075;
    }
    body {
      min-height: 100vh;
      font-family: var(--font-family-body);
      background:
        radial-gradient(circle at 12% 15%, rgba(15, 76, 255, 0.35), transparent 42%),
        radial-gradient(circle at 88% 8%, rgba(255, 107, 0, 0.32), transparent 36%),
        radial-gradient(circle at 50% 85%, rgba(0, 183, 168, 0.2), transparent 42%),
        #090f1f;
      color: var(--color-neutral-900);
      overflow-x: hidden;
    }
    .login-container {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: clamp(1rem, 2vw, 2rem);
      padding-top: 6.25rem;
      position: relative;
      isolation: isolate;
    }
    .login-container::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(var(--auth-highlight) 0.7px, transparent 0.7px);
      background-size: 4px 4px;
      opacity: 0.2;
      pointer-events: none;
      z-index: -1;
    }
    .login-card {
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(248, 251, 255, 0.86));
      backdrop-filter: blur(18px);
      border: 1px solid var(--auth-border);
      border-radius: 1.75rem;
      box-shadow: var(--auth-shadow);
      overflow: hidden;
      max-width: 27rem;
      width: 100%;
      position: relative;
    }
    .login-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, rgba(255, 255, 255, 0.5), transparent 35%);
      pointer-events: none;
    }
    .login-header {
      position: relative;
      padding: 2rem 1.5rem 1.75rem;
      text-align: center;
      color: #fff;
      background: linear-gradient(132deg, #0f4cff 0%, #00a7ff 55%, #00b7a8 100%);
    }
    .login-header h4 {
      font-family: var(--font-family-display);
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .logo-container {
      width: fit-content;
      margin: 0 auto 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      animation: fadeInLogo 0.9s ease 0.2s forwards;
      background: rgba(255, 255, 255, 0.18);
      border: 1px solid rgba(255, 255, 255, 0.45);
      box-shadow: 0 16px 28px rgba(8, 33, 84, 0.25);
    }
    .logo-container img {
      width: auto;
      height: auto;
      max-width: 8rem;
      max-height: 8rem;
      object-fit: contain;
      filter: drop-shadow(0 8px 18px rgba(15, 76, 255, 0.38));
      transition: transform 0.3s ease, filter 0.3s ease;
      animation: floating 3.2s ease-in-out infinite;
      border-radius: 0.75rem;
    }
    .logo-container img:hover {
      transform: scale(1.06) rotate(-1.5deg);
      filter: drop-shadow(0 10px 20px rgba(7, 23, 64, 0.35));
      animation: none;
    }
    .form-container {
      padding: 1.75rem 1.5rem 1.6rem;
    }
    .form-floating {
      margin-bottom: 1rem;
    }
    .form-control {
      border: 1px solid rgba(15, 76, 255, 0.18);
      border-radius: 0.9rem;
      padding: 1rem 1rem;
      font-size: 0.97rem;
      font-weight: 600;
      color: #0f172a;
      background: rgba(255, 255, 255, 0.8);
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }
    .form-control:focus {
      border-color: #0f4cff;
      box-shadow: 0 0 0 0.24rem rgba(15, 76, 255, 0.18);
      background: #fff;
    }
    .form-floating > label {
      color: var(--auth-text-soft);
      font-weight: 600;
    }
    .btn-login {
      border: 0;
      border-radius: 0.9rem;
      padding: 0.9rem 1rem;
      font-size: 0.96rem;
      font-weight: 700;
      letter-spacing: 0.01em;
      color: #fff;
      background: linear-gradient(130deg, #0f4cff 0%, #0466ff 45%, #00a7ff 100%);
      box-shadow: 0 14px 26px rgba(15, 76, 255, 0.28);
      transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    }
    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 32px rgba(15, 76, 255, 0.33);
      color: #fff;
    }
    .btn-login:disabled {
      opacity: 0.86;
      cursor: not-allowed;
    }
    .btn-login.is-loading {
      position: relative;
    }
    .btn-loading {
      display: none;
    }
    .login-alert {
      margin-top: 0.85rem;
      border: 1px solid transparent;
      border-radius: 0.9rem;
      padding: 0.72rem 0.9rem;
      font-size: 0.88rem;
      font-weight: 600;
      display: none;
    }
    .login-alert.alert-danger {
      display: block;
      background: rgba(225, 29, 72, 0.09);
      color: #a41441;
      border-color: rgba(225, 29, 72, 0.25);
    }
    .login-alert.alert-success {
      display: block;
      background: rgba(31, 157, 98, 0.1);
      color: #16653f;
      border-color: rgba(31, 157, 98, 0.26);
    }
    .footer-text {
      color: var(--auth-text-soft);
      font-size: 0.76rem;
      margin-top: 1.15rem;
    }
    .footer-text a {
      border-radius: 999px;
    }
    .portal-navbar {
      z-index: 1000;
      background: rgba(8, 15, 34, 0.74);
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(12px);
    }
    .portal-navbar .navbar-brand {
      color: #f8fbff;
      font-family: var(--font-family-display);
      font-weight: 700;
      letter-spacing: -0.01em;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .portal-navbar .navbar-brand img {
      height: 1.95rem;
      width: auto;
      border-radius: 0.5rem;
      background: rgba(255, 255, 255, 0.1);
      padding: 0.12rem;
    }
    .toast-container {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 9999;
    }
    .toast-min-width {
      min-width: 18rem;
    }
    @keyframes fadeInLogo {
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes floating {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-7px); }
    }
    @media (max-width: 576px) {
      .login-container {
        padding: 0.85rem;
        padding-top: 5.5rem;
      }
      .login-card {
        border-radius: 1.35rem;
      }
      .login-header {
        padding: 1.55rem 1.15rem 1.45rem;
      }
      .form-container {
        padding: 1.35rem 1.15rem 1.25rem;
      }
      .logo-container img {
        max-width: 6.15rem;
        max-height: 6.15rem;
      }
    }
    #logo-ornament.ornament-square {
      border-radius: 1rem;
      padding: 0.9rem;
    }
    #logo-ornament.ornament-rectangle {
      border-radius: 0.75rem 1.35rem 0.75rem 1.35rem;
      padding: 0.68rem 1.3rem;
    }
    #logo-ornament.ornament-circle {
      border-radius: 999px;
      padding: 0.95rem;
    }
  </style>
</head>
<body>
  <div class="login-container" data-testid="customer-login-container">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light position-fixed top-0 start-0 w-100 portal-navbar">
      <div class="container">
        <a class="navbar-brand" href="/">
          <img src="/img/<%= (settings && settings.logo_filename) ? settings.logo_filename : 'logo.png' %>" alt="Logo" height="30">
          Portal Pelanggan
        </a>
        <div class="navbar-nav ms-auto">
          <!-- Tombol admin login dihilangkan -->
        </div>
      </div>
    </nav>
    
    <div class="login-card" data-testid="customer-login-card">
      <div class="login-header">
        <div class="logo-container" id="logo-ornament">
          <img id="logo-img" src="/img/<%= (settings && settings.logo_filename) ? settings.logo_filename : 'logo.svg' %>?ts=<%= Date.now() %>" alt="Logo">
        </div>
        <h4 class="mb-1 fw-bold">Portal Pelanggan</h4>
        <p class="mb-0 opacity-75"><%= settings.company_header %></p>
      </div>
      <div class="form-container">
        <form id="loginForm" novalidate>
          <div class="form-floating">
            <input type="text" class="form-control" id="phone" name="phone" placeholder="Nomor HP" required autofocus pattern="08[0-9]{8,13}" data-testid="customer-login-phone">
            <label for="phone">
              <i class="bi bi-phone me-2"></i>Nomor HP
            </label>
          </div>
          <button type="submit" class="btn btn-primary btn-login w-100" id="loginBtn" data-testid="customer-login-submit">
            <span class="btn-text">
              <i class="bi bi-box-arrow-in-right me-2"></i>Masuk
            </span>
            <span class="btn-loading">
              <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Memproses...
            </span>
          </button>
        </form>
        <div id="loginAlert" class="login-alert" role="alert" aria-live="polite" data-testid="customer-login-alert"></div>
        <div class="text-center footer-text">
          <!-- Agent Registration Link -->
          <div class="mb-3">
            <h6 class="mb-2 text-muted">Ingin jadi Agent?</h6>
            <a href="/agent/login" class="btn btn-outline-success btn-sm">
              <i class="bi bi-person-plus me-2"></i>
              Daftar Agent Mandiri
            </a>
            <p class="small text-muted mt-2 mb-3">
              <i class="bi bi-info-circle me-1"></i>
              Daftar sekarang dan mulai transaksi setelah deposit
            </p>
          </div>
          
          <hr class="my-3">
          
          <p class="mb-2">
            <i class="bi bi-shield-check me-1"></i>
            Sistem keamanan terjamin
          </p>
          <p class="mb-2">
            <i class="bi bi-telephone me-1"></i>
            Butuh bantuan? Hubungi <%= settings.contact_phone || 'Admin' %>
          </p>
          
          <p class="mb-0">
            &copy; <%= new Date().getFullYear() %> <%= typeof settings !== 'undefined' && settings.footer_info ? settings.footer_info : 'ALIJAYA DIGITAL NETWORK' %>
          </p>
        </div>
      </div>
    </div>
  </div>
  <!-- Toast Container -->
  <div id="toast-container" class="toast-container"></div>

  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    // Fungsi toast notification
    function showToast(type, title, message, duration = 5000) {
        const toastId = 'toast-' + Date.now();
        const iconClass = type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : 'bi-info-circle';
        const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-primary';
        
        const toastHtml = `
            <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0 toast-min-width" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi ${iconClass} me-2"></i>
                        <strong>${title}</strong><br>
                        <small>${message}</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        `;
        
        $('#toast-container').append(toastHtml);
        const toastElement = document.getElementById(toastId);
        const toast = new bootstrap.Toast(toastElement, { delay: duration });
        toast.show();
        
        // Auto remove after hide
        toastElement.addEventListener('hidden.bs.toast', () => {
            toastElement.remove();
        });
    }

    function setLoginAlert(type, message) {
        const alert = document.getElementById('loginAlert');
        if (!alert) return;

        if (!message) {
            alert.className = 'login-alert';
            alert.textContent = '';
            return;
        }

        const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
        alert.className = `login-alert ${alertClass}`;
        alert.innerHTML = `<i class="bi ${type === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle'} me-2"></i>${message}`;
    }

    // Handler form login
    $('#loginForm').on('submit', function(e) {
        e.preventDefault();
        setLoginAlert(null, '');
        
        const phone = $('#phone').val();
        
        if (!phone || !phone.match(/^08[0-9]{8,13}$/)) {
            setLoginAlert('error', 'Nomor HP harus valid (08xxxxxxxxxx)');
            showToast('error', 'Error', 'Nomor HP harus valid (08xxxxxxxxxx)');
            return;
        }
        
        // Loading state
        const $btn = $('#loginBtn');
        const $btnText = $btn.find('.btn-text');
        const $btnLoading = $btn.find('.btn-loading');
        
        $btn.prop('disabled', true);
        $btn.addClass('is-loading').attr('aria-busy', 'true');
        $btnText.hide();
        $btnLoading.show();
        
        // Kirim request
        $.ajax({
            url: '/customer/login',
            method: 'POST',
            data: { phone },
            success: function(response) {
                if (response.success) {
                    const target = response.redirect || '/customer/dashboard';
                    setLoginAlert('success', 'Login berhasil. Anda akan diarahkan ke dashboard.');
                    showToast('success', 'Login Berhasil', 'Mengalihkan...');
                    setTimeout(() => {
                        window.location.href = target;
                    }, 800);
                } else {
                    setLoginAlert('error', response.message || 'Nomor HP tidak terdaftar');
                    showToast('error', 'Login Gagal', response.message || 'Nomor HP tidak terdaftar');
                }
            },
            error: function(xhr) {
                const errorMsg = xhr.responseJSON?.message || 'Terjadi kesalahan saat login';
                setLoginAlert('error', errorMsg);
                showToast('error', 'Error', errorMsg);
            },
            complete: function() {
                // Reset button
                $btn.prop('disabled', false);
                $btn.removeClass('is-loading').removeAttr('aria-busy');
                $btnText.show();
                $btnLoading.hide();
            }
        });
    });

    // Ornamen dinamis untuk logo
    window.addEventListener('DOMContentLoaded', function() {
      const logoImg = document.getElementById('logo-img');
      const ornament = document.getElementById('logo-ornament');
      function updateOrnament() {
        if (!logoImg.naturalWidth || !logoImg.naturalHeight) return;
        const w = logoImg.naturalWidth;
        const h = logoImg.naturalHeight;
        ornament.classList.remove('ornament-square', 'ornament-rectangle', 'ornament-circle');
        if (Math.abs(w - h) < 10) {
          ornament.classList.add('ornament-square');
        } else if (w > h * 1.2) {
          ornament.classList.add('ornament-rectangle');
        } else if (h > w * 1.2) {
          ornament.classList.add('ornament-rectangle');
        } else {
          ornament.classList.add('ornament-square');
        }
      }
      if (logoImg.complete) {
        updateOrnament();
      } else {
        logoImg.onload = updateOrnament;
      }
    });
  </script>
</body>
</html> 
