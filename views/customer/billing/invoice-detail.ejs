<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - <%= appSettings.companyHeader %></title>
    <link rel="manifest" href="/manifest.webmanifest">
    <meta name="theme-color" content="#0B1437">
    <link rel="apple-touch-icon" href="/img/icons/icon-192.png">
    <link rel="stylesheet" href="/css/pwa.css">
    <link rel="stylesheet" href="/css/customer-responsive.css">
    <script defer src="/js/pwa-install.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet">
    <style>

        :root {
            --ink: #030712;
            --panel: #0f172a;
            --panel-soft: rgba(15, 23, 42, 0.85);
            --panel-edge: rgba(148, 163, 184, 0.25);
            --accent: #06b6d4;
            --accent-strong: #2dd4bf;
            --muted: #94a3b8;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: radial-gradient(circle at top right, rgba(14, 165, 233, 0.24), transparent 35%), #030712;
            font-family: 'Manrope', 'Segoe UI', system-ui, sans-serif;
            color: #e2e8f0;
        }

        .invoice-detail-page {
            background: radial-gradient(circle at 10% 20%, rgba(59, 130, 246, 0.25), transparent 45%), var(--ink);
        }

        .container {
            max-width: 1100px;
        }

        .customer-header h2 {
            font-family: 'Playfair Display', 'Times New Roman', serif;
            letter-spacing: 0.04em;
            text-transform: none;
        }

        .customer-header p {
            color: var(--muted);
        }

        .page-header {
            border-bottom: 1px solid rgba(148, 163, 184, 0.2);
            padding-bottom: 0.75rem;
        }

        .header-actions {
            gap: 0.4rem;
        }

        .hero-card {
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: linear-gradient(135deg, #11163d 0%, #0b0f2c 65%, #030712 100%);
            border-radius: 18px;
            padding: 1.7rem;
            position: relative;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(2, 6, 23, 0.55);
        }

        .hero-card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 70% -10%, rgba(14, 165, 233, 0.3), transparent 45%);
            pointer-events: none;
        }

        .hero-grid {
            position: relative;
            display: flex;
            justify-content: space-between;
            gap: 2rem;
            align-items: flex-start;
        }

        .hero-title {
            font-size: 2.2rem;
            margin: 0.2rem 0 0.6rem;
        }

        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-size: 0.75rem;
            color: #a5b4fc;
        }

        .hero-status {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .status-pill {
            font-size: 0.9rem;
            padding: 0.35rem 0.9rem;
            border-radius: 999px;
        }

        .hero-amount {
            text-align: right;
        }

        .hero-label {
            text-transform: uppercase;
            letter-spacing: 0.3em;
            font-size: 0.7rem;
            color: var(--muted);
            margin-bottom: 0.2rem;
        }

        .hero-value {
            font-size: 2rem;
            font-weight: 700;
            margin: 0;
        }

        .hero-dates {
            font-weight: 500;
            color: var(--muted);
            margin-top: 0.4rem;
        }

        .info-card,
        .data-card {
            background: rgba(15, 23, 42, 0.85);
            border: 1px solid var(--panel-edge);
            border-radius: 18px;
            box-shadow: 0 20px 35px rgba(2, 6, 23, 0.35);
        }

        .info-card .card-header,
        .data-card .card-header {
            background: transparent;
            border-bottom: none;
        }

        .info-grid .info-pair {
            background: var(--panel-soft);
            border-radius: 12px;
            padding: 0.9rem;
        }

        .info-pair dt {
            font-size: 0.75rem;
            color: var(--muted);
            letter-spacing: 0.12em;
            text-transform: uppercase;
            margin-bottom: 0.25rem;
        }

        .info-pair dd {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 600;
        }

        .package-panel {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(59, 130, 246, 0.08);
            border-radius: 14px;
            padding: 1rem;
            border: 1px dashed rgba(59, 130, 246, 0.3);
        }

        .package-panel .package-details {
            max-width: 320px;
        }

        .package-panel .package-details p {
            margin: 0;
        }

        .package-preview {
            width: 100px;
            height: auto;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 25px rgba(2, 6, 23, 0.55);
        }

        .notes-panel {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(148, 163, 184, 0.2);
            padding: 1rem 1.25rem;
            border-radius: 12px;
        }

        .notes-panel h6 {
            margin-bottom: 0.45rem;
        }

        .panel-heading {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            color: var(--muted);
        }

        .table-responsive {
            border-radius: 12px;
            overflow: hidden;
        }

        .table-responsive table {
            background: rgba(15, 23, 42, 0.65);
            border: none;
        }

        .table-responsive th {
            background: rgba(15, 23, 42, 0.8);
        }

        .table-responsive td,
        .table-responsive th {
            border-color: rgba(148, 163, 184, 0.3);
        }

        .processing-indicator {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35rem;
            margin-top: 1rem;
            color: var(--muted);
        }

        .payment-card .alert {
            font-size: 0.9rem;
        }

        .payment-card .text-muted {
            font-size: 0.85rem;
        }

        .payment-card .spinner-border {
            width: 2rem;
            height: 2rem;
        }

        #payment-processing {
            display: none;
        }

        .footer-brand {
            font-weight: 600;
        }

        @media (max-width: 768px) {
            .hero-grid {
                flex-direction: column;
                text-align: left;
            }

            .hero-amount {
                text-align: left;
            }

            .header-actions {
                width: 100%;
                justify-content: flex-start;
            }
        }

        @media print {
            body {
                background: #fff;
                color: #030712;
            }

            .card,
            .hero-card {
                box-shadow: none;
                border: 1px solid #d1d5db;
            }

            footer,
            .bottom-nav {
                display: none;
            }
        }
    </style>
</head>
<body class="invoice-detail-page" data-testid="customer-invoice-detail-page">
    <!-- Navbar atas dihilangkan untuk tampilan mobile minimalis -->
    <div class="container mt-4" data-testid="invoice-detail-container">
        <div class="page-header d-flex justify-content-between align-items-start flex-wrap mb-3" data-testid="invoice-detail-header">
            <div class="customer-header">
                <h2 class="mb-1">Detail Tagihan</h2>
                <p class="text-muted mb-0">Informasi lengkap tagihan Anda</p>
            </div>
            <div class="header-actions d-flex" data-testid="invoice-hero-actions">
                <a href="/customer/billing/invoices" class="btn btn-outline-light btn-sm" data-testid="invoice-detail-back">
                    <i class="bi bi-arrow-left"></i> Kembali
                </a>
                <a href="/customer/billing/invoices/<%= invoice.id %>/print" class="btn btn-light btn-sm" target="_blank" data-testid="invoice-detail-print">
                    <i class="bi bi-printer"></i> Print
                </a>
            </div>
        </div>
        <section class="card hero-card mb-4" data-testid="invoice-hero">
            <div class="hero-grid">
                <div>
                    <p class="eyebrow">Tagihan Aktif</p>
                    <h1 class="hero-title">Tagihan #<%= invoice.invoice_number %></h1>
                    <p class="mb-1">Silakan periksa detail, pembayaran, dan riwayat transaksi Anda di bawah.</p>
                    <div class="hero-status" data-testid="invoice-hero-status">
                        <strong class="text-muted">Status:</strong>
                        <% if (invoice.status === 'paid') { %>
                            <span class="badge bg-success status-pill" data-testid="hero-status-paid">LUNAS</span>
                        <% } else if (invoice.status === 'unpaid') { %>
                            <% if (new Date(invoice.due_date) < new Date()) { %>
                                <span class="badge bg-danger status-pill" data-testid="hero-status-overdue">TERLAMBAT</span>
                            <% } else { %>
                                <span class="badge bg-warning status-pill" data-testid="hero-status-unpaid">BELUM LUNAS</span>
                            <% } %>
                        <% } %>
                    </div>
                    <p class="text-muted mt-2 mb-0">
                        <strong>Jatuh Tempo:</strong>
                        <% if (new Date(invoice.due_date) < new Date() && invoice.status === 'unpaid') { %>
                            <span class="text-danger"><%= new Date(invoice.due_date).toLocaleDateString('id-ID') %></span>
                        <% } else { %>
                            <%= new Date(invoice.due_date).toLocaleDateString('id-ID') %>
                        <% } %>
                        &nbsp;|&nbsp;
                        Dibuat: <%= new Date(invoice.created_at).toLocaleDateString('id-ID') %>
                    </p>
                </div>
                <div class="hero-amount" data-testid="invoice-hero-amount">
                    <p class="hero-label">Total Tagihan</p>
                    <p class="hero-value">Rp <%= parseFloat(invoice.amount).toLocaleString('id-ID') %></p>
                    <p class="hero-dates">Bayar sebelum jatuh tempo agar terhindar denda.</p>
                </div>
            </div>
        </section>
        <div class="row g-4">
            <div class="col-lg-8">
                <article class="card info-card" data-testid="invoice-info-card">
                    <div class="card-header">
                        <h5 class="mb-0 panel-heading">
                            <i class="bi bi-info-circle"></i>
                            <span>Informasi Tagihan</span>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="info-grid row g-3" data-testid="invoice-info-grid">
                            <div class="col-sm-6">
                                <dl class="info-pair">
                                    <dt>No. Tagihan</dt>
                                    <dd><%= invoice.invoice_number %></dd>
                                </dl>
                            </div>
                            <div class="col-sm-6">
                                <dl class="info-pair">
                                    <dt>Jumlah</dt>
                                    <dd>Rp <%= parseFloat(invoice.amount).toLocaleString('id-ID') %></dd>
                                </dl>
                            </div>
                            <div class="col-sm-6">
                                <dl class="info-pair">
                                    <dt>Kecepatan</dt>
                                    <dd><%= invoice.package_speed %></dd>
                                </dl>
                            </div>
                            <div class="col-sm-6">
                                <dl class="info-pair">
                                    <dt>Status</dt>
                                    <dd>
                                        <% if (invoice.status === 'paid') { %>
                                            <span class="badge bg-success status-pill">LUNAS</span>
                                        <% } else if (invoice.status === 'unpaid') { %>
                                            <% if (new Date(invoice.due_date) < new Date()) { %>
                                                <span class="badge bg-danger status-pill">TERLAMBAT</span>
                                            <% } else { %>
                                                <span class="badge bg-warning status-pill">BELUM LUNAS</span>
                                            <% } %>
                                        <% } %>
                                    </dd>
                                </dl>
                            </div>
                            <div class="col-sm-6">
                                <dl class="info-pair">
                                    <dt>Tanggal Dibuat</dt>
                                    <dd><%= new Date(invoice.created_at).toLocaleDateString('id-ID') %></dd>
                                </dl>
                            </div>
                            <div class="col-sm-6">
                                <dl class="info-pair">
                                    <dt>Jatuh Tempo</dt>
                                    <dd>
                                        <% if (new Date(invoice.due_date) < new Date() && invoice.status === 'unpaid') { %>
                                            <span class="text-danger"><%= new Date(invoice.due_date).toLocaleDateString('id-ID') %></span>
                                        <% } else { %>
                                            <%= new Date(invoice.due_date).toLocaleDateString('id-ID') %>
                                        <% } %>
                                    </dd>
                                </dl>
                            </div>
                            <% if (invoice.payment_date) { %>
                                <div class="col-sm-6">
                                    <dl class="info-pair">
                                        <dt>Tanggal Bayar</dt>
                                        <dd><%= new Date(invoice.payment_date).toLocaleDateString('id-ID') %></dd>
                                    </dl>
                                </div>
                            <% } %>
                            <div class="col-12">
                                <div class="package-panel" data-testid="invoice-package-panel">
                                    <div class="package-details">
                                        <p class="text-muted mb-1">Paket</p>
                                        <p class="fs-5 fw-semibold mb-0"><%= invoice.package_name %></p>
                                    </div>
                                    <% if (invoice.package_image) { %>
                                        <div class="package-visual">
                                            <img src="/img/packages/<%= invoice.package_image %>" alt="<%= invoice.package_name %>" class="package-preview">
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <% if (invoice.notes) { %>
                            <div class="notes-panel mt-4" data-testid="invoice-notes">
                                <h6 class="mb-2">Catatan</h6>
                                <p class="mb-0 text-muted"><%= invoice.notes %></p>
                            </div>
                        <% } %>
                    </div>
                </article>
                <% if (payments && payments.length > 0) { %>
                    <div class="card mt-4" data-testid="payment-history-card">
                        <div class="card-header panel-heading">
                            <i class="bi bi-cash-stack"></i>
                            <span>Riwayat Pembayaran</span>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0" data-testid="payment-history-table">
                                    <thead>
                                        <tr>
                                            <th>Tanggal</th>
                                            <th>Jumlah</th>
                                            <th>Metode</th>
                                            <th>Referensi</th>
                                            <th>Catatan</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% payments.forEach(function(payment) { %>
                                            <tr>
                                                <td><%= new Date(payment.payment_date).toLocaleDateString('id-ID') %></td>
                                                <td>Rp <%= parseFloat(payment.amount).toLocaleString('id-ID') %></td>
                                                <td>
                                                    <% if (payment.payment_method === 'cash') { %>
                                                        <span class="badge bg-success">Tunai</span>
                                                    <% } else if (payment.payment_method === 'transfer') { %>
                                                        <span class="badge bg-primary">Transfer</span>
                                                    <% } else if (payment.payment_method === 'qris') { %>
                                                        <span class="badge bg-info">QRIS</span>
                                                    <% } else if (payment.payment_method === 'ewallet') { %>
                                                        <span class="badge bg-warning">E-Wallet</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary"><%= payment.payment_method %></span>
                                                    <% } %>
                                                </td>
                                                <td><%= payment.reference_number || '-' %></td>
                                                <td><%= payment.notes || '-' %></td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
            <div class="col-lg-4">
                <div class="card data-card mb-4" data-testid="customer-info-card">
                    <div class="card-header panel-heading">
                        <i class="bi bi-person"></i>
                        <span>Informasi Pelanggan</span>
                    </div>
                    <div class="card-body">
                        <p class="mb-2"><strong>Nama:</strong><br><%= invoice.customer_name %></p>
                        <p class="mb-2"><strong>Username:</strong><br><%= invoice.customer_username %></p>
                        <p class="mb-0"><strong>Telepon:</strong><br><%= invoice.customer_phone || '-' %></p>
                    </div>
                </div>
                <div class="card data-card mb-4" data-testid="payment-options-card">
                    <div class="card-header panel-heading bg-transparent">
                        <i class="bi bi-credit-card"></i>
                        <span>Pembayaran Online</span>
                    </div>
                    <div class="card-body payment-card">
                        <% if (invoice.status === 'unpaid') { %>
                            <div class="alert alert-success mb-3">
                                <i class="bi bi-check-circle"></i>
                                Status UNPAID - Metode pembayaran tersedia.
                            </div>
                            <p class="text-muted mb-3">Pilih metode pembayaran yang Anda inginkan:</p>
                            <div id="payment-methods-container" data-testid="payment-methods-container">
                                <div class="text-center py-3">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading payment methods...</span>
                                    </div>
                                    <p class="mt-2 mb-0">Memuat metode pembayaran...</p>
                                </div>
                            </div>
                            <div id="payment-processing" class="processing-indicator" data-testid="payment-processing">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2 mb-0">Memproses pembayaran...</p>
                            </div>
                        <% } else { %>
                            <div class="alert alert-danger mb-3">
                                <i class="bi bi-x-circle"></i>
                                Status bukan UNPAID (status: "<%= invoice.status %>") - Payment tidak tersedia
                            </div>
                            <p class="mb-0 text-muted">
                                Invoice ini tidak dapat dibayar karena statusnya bukan 'unpaid'.
                            </p>
                        <% } %>
                    </div>
                </div>
                <div class="card data-card mb-4" data-testid="payment-instructions-card">
                    <div class="card-header panel-heading bg-transparent">
                        <i class="bi bi-exclamation-triangle"></i>
                        <span>Pembayaran Manual</span>
                    </div>
                    <div class="card-body">
                        <p class="mb-3">Atau lakukan pembayaran melalui:</p>
                        <ul class="list-unstyled mb-3">
                            <li class="mb-2">
                                <i class="bi bi-cash text-success"></i>
                                <strong>Tunai:</strong> <%= appSettings.payment_cash_address %><br>
                                <small class="text-muted">Jam: <%= appSettings.payment_cash_hours %></small>
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-bank text-primary"></i>
                                <strong>Transfer:</strong> <%= appSettings.payment_bank_name %><br>
                                <small class="text-muted">
                                    No. Rek: <%= appSettings.payment_account_number %><br>
                                    A/N: <%= appSettings.payment_account_holder %>
                                </small>
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-whatsapp text-success"></i>
                                <strong>Kontak:</strong>
                                <a href="https://wa.me/62<%= appSettings.contact_whatsapp.replace(/^0/, '') %>" target="_blank" class="text-decoration-none">
                                    <%= appSettings.contact_whatsapp %>
                                </a>
                            </li>
                        </ul>
                        <p class="text-muted mb-0">
                            Hubungi admin untuk konfirmasi pembayaran manual.
                        </p>
                    </div>
                </div>
                <div class="card data-card" data-testid="invoice-actions-card">
                    <div class="card-header panel-heading bg-transparent">
                        <i class="bi bi-gear"></i>
                        <span>Aksi</span>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="/customer/billing/invoices/<%= invoice.id %>/print" class="btn btn-primary" target="_blank">
                                <i class="bi bi-printer"></i> Print Tagihan
                            </a>
                            <a href="/customer/billing/invoices" class="btn btn-outline-light">
                                <i class="bi bi-arrow-left"></i> Kembali ke Daftar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer class="bg-light mt-5 py-4" data-testid="invoice-detail-footer">
        <div class="container text-center">
            <p class="mb-0 text-muted">
                <%= appSettings.footerInfo %>
            </p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/customer-mobile.js"></script>
    <!-- Bottom nav (mobile) 5 menu -->
    <nav class="bottom-nav d-md-none" data-testid="invoice-detail-bottom-nav">
        <a class="nav-item" href="/customer/billing/dashboard">
            <i class="bi bi-speedometer2"></i>
            <span>Billing</span>
        </a>
        <a class="nav-item" href="/customer/trouble/report">
            <i class="bi bi-exclamation-triangle"></i>
            <span>Laporan</span>
        </a>
        <a class="nav-item home-button" href="/customer/dashboard">
            <i class="bi bi-house"></i>
            <span>Home</span>
        </a>
        <a class="nav-item" href="/customer/billing/invoices">
            <i class="bi bi-receipt"></i>
            <span>Invoice</span>
        </a>
        <a class="nav-item" href="/customer/billing/profile">
            <i class="bi bi-person"></i>
            <span>Profile</span>
        </a>
    </nav>
    <script>
        // Load payment methods dynamically
        async function loadPaymentMethods() {
            try {
                const response = await fetch('/customer/billing/api/payment-methods');
                const result = await response.json();

                if (result.success && result.methods) {
                    renderPaymentMethods(result.methods);
                } else {
                    showPaymentMethodsError('Gagal memuat metode pembayaran: ' + (result.message || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error loading payment methods:', error);
                showPaymentMethodsError('Terjadi kesalahan saat memuat metode pembayaran');
            }
        }

        function renderPaymentMethods(methods) {
            const container = document.getElementById('payment-methods-container');

            if (!methods || methods.length === 0) {
                container.innerHTML = `
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                        Tidak ada metode pembayaran yang tersedia saat ini.
                    </div>
                `;
                return;
            }

            let html = '<div class="row g-2 mb-3">';

            methods.forEach(method => {
                // Check if amount meets minimum requirement
                const invoiceAmount = parseFloat('<%= invoice.amount %>');
                const isDisabled = method.minimum_amount && invoiceAmount < method.minimum_amount;
                const disabledClass = isDisabled ? 'disabled' : '';
                const disabledTitle = isDisabled ? `Minimal pembayaran: Rp ${method.minimum_amount?.toLocaleString('id-ID')}` : '';

                html += `
                    <div class="col-md-6">
                        <button class="btn btn-outline-${method.color} w-100 payment-method ${disabledClass}" 
                                data-gateway="${method.gateway}" 
                                data-method="${method.method}"
                                ${isDisabled ? 'disabled' : ''}
                                title="${disabledTitle}">
                            <i class="${method.icon}"></i><br>
                            <small>${method.name}</small>
                            <br><small class="text-muted">Fee: ${method.fee_customer || 'Gratis'}</small>
                            ${isDisabled ? `<br><small class="text-danger">Min: Rp ${method.minimum_amount?.toLocaleString('id-ID')}</small>` : ''}
                        </button>
                    </div>
                `;
            });

            html += '</div>';
            container.innerHTML = html;

            // Bind event listeners to new buttons
            bindPaymentMethodEvents();
        }

        function showPaymentMethodsError(message) {
            const container = document.getElementById('payment-methods-container');
            container.innerHTML = `
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle"></i>
                    ${message}
                </div>
                <button class="btn btn-outline-primary w-100" onclick="loadPaymentMethods()">
                    <i class="bi bi-arrow-clockwise"></i> Coba Lagi
                </button>
            `;
        }

        // Handle payment method selection
        function bindPaymentMethodEvents() {
            document.querySelectorAll('.payment-method').forEach(button => {
                button.addEventListener('click', async function() {
                    if (this.disabled) return;

                    const gateway = this.dataset.gateway;
                    const method = this.dataset.method;
                    const invoiceId = parseInt('<%= invoice.id %>');

                    // Show loading
                    document.getElementById('payment-processing').style.display = 'block';
                    this.disabled = true;

                    try {
                        const response = await fetch('/customer/billing/create-payment', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                invoice_id: invoiceId,
                                gateway: gateway,
                                method: method
                            })
                        });

                        const result = await response.json();

                        if (result.success) {
                            // Redirect to payment URL
                            if (result.data && result.data.payment_url) {
                                window.open(result.data.payment_url, '_blank');

                                // Refresh page after 3 seconds
                                setTimeout(() => {
                                    window.location.reload();
                                }, 3000);
                            } else {
                                alert('Error: Payment URL tidak ditemukan');
                            }
                        } else {
                            alert('Error: ' + (result.message || 'Gagal membuat pembayaran'));
                        }
                    } catch (error) {
                        console.error('Payment error:', error);
                        alert('Terjadi kesalahan saat membuat pembayaran: ' + error.message);
                    } finally {
                        // Hide loading
                        document.getElementById('payment-processing').style.display = 'none';
                        this.disabled = false;
                    }
                });
            });
        }

        // Load payment methods when page loads
        document.addEventListener('DOMContentLoaded', function() {
            // Check if invoice status is unpaid
            const invoiceStatus = '<%= invoice.status %>';
            if (invoiceStatus === 'unpaid') {
                loadPaymentMethods();
            }
        });
    </script>
</body>
</html>
