<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title><%= title || 'Admin Dashboard' %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Sora:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --admin-bg: #090f1e;
            --admin-surface: rgba(12, 22, 44, 0.82);
            --admin-surface-soft: rgba(255, 255, 255, 0.08);
            --admin-border: rgba(149, 173, 219, 0.22);
            --admin-text: #deebff;
            --admin-text-muted: #9db0d4;
            --admin-accent: #4fd1c5;
            --admin-accent-2: #ffcf5d;
            --admin-topbar-bg: rgba(255, 255, 255, 0.82);
            --admin-topbar-text: #132340;
            --admin-main-bg: rgba(255, 255, 255, 0.72);
            --admin-main-border: rgba(73, 98, 145, 0.18);
            --admin-main-shadow: 0 24px 54px rgba(10, 24, 53, 0.16);
            --admin-radius-xl: 1.3rem;
            --admin-radius-lg: 1rem;
            --admin-sidebar-width: 18.5rem;
        }

        * {
            box-sizing: border-box;
        }

        body.admin-shell-body {
            margin: 0;
            min-height: 100vh;
            color: #1b2d4d;
            font-family: "IBM Plex Sans", sans-serif;
            background:
                radial-gradient(circle at 18% -5%, #214b85 0%, rgba(33, 75, 133, 0) 42%),
                radial-gradient(circle at 88% 10%, #0f8ea1 0%, rgba(15, 142, 161, 0) 37%),
                radial-gradient(circle at 52% 100%, #0c2d5f 0%, rgba(12, 45, 95, 0) 48%),
                var(--admin-bg);
            background-attachment: fixed;
        }

        .admin-shell {
            position: relative;
            min-height: 100vh;
            padding: 0;
        }

        .admin-shell-row {
            min-height: 100vh;
        }

        .admin-sidebar {
            position: sticky;
            top: 0;
            z-index: 1036;
            min-height: 100vh;
            width: var(--admin-sidebar-width);
            max-width: 100%;
            padding: 1.6rem 1.15rem 1.25rem;
            border-right: 1px solid var(--admin-border);
            background:
                linear-gradient(162deg, rgba(255, 255, 255, 0.08), rgba(79, 209, 197, 0.03) 65%),
                var(--admin-surface);
            backdrop-filter: blur(12px);
            box-shadow: 22px 0 48px rgba(2, 6, 18, 0.33);
            color: var(--admin-text);
            display: flex;
            flex-direction: column;
            gap: 1rem;
            transition: transform .3s ease;
        }

        .admin-sidebar::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background-image: linear-gradient(transparent 95%, rgba(79, 209, 197, 0.16));
            background-size: 100% 18px;
            opacity: .26;
        }

        .admin-sidebar-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 5.3rem;
            margin-bottom: .5rem;
            padding: .85rem;
            border: 1px solid var(--admin-border);
            border-radius: .9rem;
            background: rgba(255, 255, 255, 0.03);
        }

        .admin-sidebar-logo {
            max-width: 7.6rem;
            max-height: 3.4rem;
            width: auto;
            height: auto;
            object-fit: contain;
        }

        .admin-sidebar-title {
            margin: 0;
            font-family: "Sora", sans-serif;
            font-size: .72rem;
            line-height: 1;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: var(--admin-text-muted);
        }

        .admin-nav {
            display: flex;
            flex-direction: column;
            gap: .35rem;
            margin-top: .2rem;
        }

        .admin-nav-link {
            position: relative;
            display: flex;
            align-items: center;
            gap: .75rem;
            margin: 0;
            padding: .72rem .86rem;
            color: var(--admin-text);
            text-decoration: none;
            border: 1px solid transparent;
            border-radius: .78rem;
            transition: transform .18s ease, border-color .2s ease, background-color .2s ease, color .2s ease;
        }

        .admin-nav-link i {
            width: 1.2rem;
            text-align: center;
            color: var(--admin-text-muted);
        }

        .admin-nav-link:hover {
            color: #fff;
            transform: translateX(2px);
            border-color: rgba(255, 255, 255, 0.18);
            background: rgba(255, 255, 255, 0.09);
        }

        .admin-nav-link:hover i {
            color: var(--admin-accent);
        }

        .admin-nav-link.active {
            color: #fff;
            border-color: rgba(79, 209, 197, 0.46);
            background: linear-gradient(110deg, rgba(79, 209, 197, 0.24), rgba(255, 207, 93, 0.16));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
        }

        .admin-nav-link.active i {
            color: var(--admin-accent-2);
        }

        .admin-shell-main {
            position: relative;
            flex: 1;
            min-width: 0;
            padding: 1.1rem 1.25rem 1.35rem;
        }

        .admin-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .8rem;
            padding: .75rem .95rem;
            border: 1px solid rgba(18, 44, 79, 0.12);
            border-radius: var(--admin-radius-lg);
            background: var(--admin-topbar-bg);
            backdrop-filter: blur(9px);
            box-shadow: 0 10px 30px rgba(5, 18, 44, 0.1);
        }

        .admin-topbar-context {
            min-width: 0;
        }

        .admin-topbar-kicker {
            margin: 0;
            color: #49658f;
            font-size: .73rem;
            letter-spacing: .13em;
            text-transform: uppercase;
            font-weight: 600;
        }

        .admin-topbar-title {
            margin: .08rem 0 0;
            font-family: "Sora", sans-serif;
            color: var(--admin-topbar-text);
            font-size: clamp(1.05rem, 1.2vw, 1.38rem);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .admin-topbar-badge {
            flex-shrink: 0;
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            margin: 0;
            padding: .45rem .68rem;
            border: 1px solid rgba(79, 209, 197, 0.35);
            border-radius: 999px;
            color: #1b3c57;
            font-size: .76rem;
            font-weight: 600;
            background: rgba(79, 209, 197, 0.14);
        }

        .admin-sidebar-toggle {
            display: none;
            flex-shrink: 0;
            border: 0;
            width: 2.15rem;
            height: 2.15rem;
            border-radius: .7rem;
            background: #10284b;
            color: #dfeeff;
            box-shadow: 0 8px 18px rgba(6, 18, 42, 0.3);
        }

        .admin-main-content {
            margin-top: .95rem;
            padding: 1rem;
            border: 1px solid var(--admin-main-border);
            border-radius: var(--admin-radius-xl);
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(244, 248, 255, 0.84)),
                var(--admin-main-bg);
            box-shadow: var(--admin-main-shadow);
        }

        .admin-shell-overlay {
            position: fixed;
            inset: 0;
            z-index: 1035;
            background: rgba(2, 10, 28, 0.48);
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s ease;
        }

        .admin-shell-overlay.show {
            opacity: 1;
            pointer-events: auto;
        }

        .restart-notif {
            z-index: 1090;
            min-width: 18.5rem;
            border-radius: .8rem;
            border: 1px solid rgba(17, 39, 73, 0.18);
            box-shadow: 0 18px 40px rgba(7, 18, 44, 0.2);
            backdrop-filter: blur(5px);
        }

        @media (max-width: 1024px) {
            .admin-shell-main {
                padding: 1rem;
            }

            .admin-main-content {
                padding: .9rem;
            }
        }

        @media (max-width: 768px) {
            body.admin-shell-body {
                overflow-x: hidden;
            }

            .admin-sidebar {
                position: fixed;
                left: 0;
                transform: translateX(-108%);
                width: min(86vw, 19rem);
                padding-top: 1rem;
            }

            .admin-sidebar.show {
                transform: translateX(0);
            }

            .admin-shell-main {
                width: 100%;
                margin-left: 0;
                padding: .8rem;
            }

            .admin-sidebar-toggle {
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }

            .admin-topbar {
                padding: .68rem .72rem;
            }

            .admin-topbar-title {
                white-space: normal;
            }

            .admin-topbar-badge {
                display: none;
            }

            .admin-main-content {
                margin-top: .75rem;
                border-radius: 1rem;
            }
        }

        @media (max-width: 480px) {
            .admin-shell-main {
                padding: .6rem;
            }

            .admin-topbar-kicker {
                letter-spacing: .1em;
                font-size: .67rem;
            }

            .admin-topbar-title {
                font-size: 1rem;
            }

            .admin-main-content {
                padding: .72rem;
            }
        }
    </style>
</head>
<body class="admin-shell-body">
<div class="container-fluid admin-shell" data-testid="admin-shell-root">
    <div class="admin-shell-overlay" id="adminSidebarOverlay" data-testid="admin-shell-overlay"></div>
    <div class="row g-0 admin-shell-row">
        <nav
            class="sidebar admin-sidebar d-flex flex-column"
            id="adminSidebar"
            data-testid="admin-shell-sidebar"
            aria-label="Navigasi Admin"
        >
            <p class="admin-sidebar-title" data-testid="admin-shell-nav-kicker">Admin Panel</p>
            <div class="admin-sidebar-brand" data-testid="admin-shell-brand">
                <img
                    src="/img/<%= typeof settings !== 'undefined' && settings.logo_filename ? settings.logo_filename : 'logo.png' %>?ts=<%= Date.now() %>"
                    alt="Logo"
                    class="admin-sidebar-logo"
                >
            </div>
            <div class="admin-nav" data-testid="admin-shell-nav">
                <a href="/admin/dashboard" class="admin-nav-link <%= page === 'dashboard' ? 'active' : '' %>" data-testid="admin-shell-nav-dashboard"><i class="bi bi-house"></i> Dashboard</a>
                <a href="/admin/genieacs" class="admin-nav-link <%= page === 'genieacs' ? 'active' : '' %>" data-testid="admin-shell-nav-genieacs"><i class="bi bi-hdd-network"></i> GenieACS</a>
                <a href="/admin/mikrotik" class="admin-nav-link <%= page === 'mikrotik' ? 'active' : '' %>" data-testid="admin-shell-nav-mikrotik"><i class="bi bi-router"></i> Mikrotik</a>
                <a href="/admin/settings" class="admin-nav-link <%= page === 'setting' ? 'active' : '' %>" data-testid="admin-shell-nav-settings"><i class="bi bi-gear"></i> Setting</a>
                <a href="/admin/logout" class="admin-nav-link" data-testid="admin-shell-nav-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </nav>
        <section class="admin-shell-main" data-testid="admin-shell-stage">
            <header class="admin-topbar" data-testid="admin-shell-topbar">
                <button
                    type="button"
                    id="adminSidebarToggle"
                    class="admin-sidebar-toggle"
                    aria-label="Toggle sidebar"
                    aria-controls="adminSidebar"
                    data-testid="admin-shell-toggle"
                >
                    <i class="bi bi-list"></i>
                </button>
                <div class="admin-topbar-context">
                    <p class="admin-topbar-kicker">Kontrol & Monitoring</p>
                    <h1 class="admin-topbar-title"><%= title || 'Admin Dashboard' %></h1>
                </div>
                <p class="admin-topbar-badge" data-testid="admin-shell-status-badge">
                    <i class="bi bi-shield-check"></i>
                    Akses Admin Aktif
                </p>
            </header>
            <main class="main-content admin-main-content" data-testid="admin-shell-content">
                <%- body %>
            </main>
        </section>
    </div>
</div>

<!-- Modal Konfirmasi Restart Mikrotik -->
<div class="modal fade" id="restartMikrotikModal" tabindex="-1" aria-labelledby="restartMikrotikModalLabel" aria-hidden="true" data-testid="admin-shell-restart-modal">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="restartMikrotikModalLabel"><i class="bi bi-arrow-repeat"></i> Konfirmasi Restart Mikrotik</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Apakah Anda yakin ingin <b>restart Mikrotik</b>?<br>Router akan reboot dan koneksi internet pelanggan akan terputus sementara.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="button" class="btn btn-danger" id="confirmRestartMikrotik">Restart</button>
      </div>
    </div>
  </div>
</div>

<!-- Notifikasi -->
<div id="restartNotif" class="alert d-none position-fixed top-0 end-0 m-4 restart-notif" data-testid="admin-shell-restart-notif"></div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(function() {
  function closeSidebar() {
    $('#adminSidebar').removeClass('show');
    $('#adminSidebarOverlay').removeClass('show');
    $('body').removeClass('admin-shell-sidebar-open');
  }

  $('#adminSidebarToggle').on('click', function() {
    $('#adminSidebar').toggleClass('show');
    $('#adminSidebarOverlay').toggleClass('show');
    $('body').toggleClass('admin-shell-sidebar-open');
  });

  $('#adminSidebarOverlay').on('click', function() {
    closeSidebar();
  });

  $(window).on('resize', function() {
    if (window.innerWidth > 768) {
      closeSidebar();
    }
  });

  // Tampilkan modal saat tombol sidebar diklik
  $(document).on('click', '#restartMikrotikBtn', function(e) {
    e.preventDefault();
    $('#restartMikrotikModal').modal('show');
  });
  // Handle konfirmasi restart
  $('#confirmRestartMikrotik').on('click', function() {
    $('#restartMikrotikModal').modal('hide');
    // Kirim request ke backend
    $.ajax({
      url: '/admin/mikrotik/restart',
      method: 'POST',
      success: function(res) {
        let notif = $('#restartNotif');
        if(res.success) {
          notif.removeClass('d-none alert-danger').addClass('alert-success').text(res.message || 'Mikrotik berhasil direstart!');
        } else {
          notif.removeClass('d-none alert-success').addClass('alert-danger').text(res.message || 'Gagal restart Mikrotik!');
        }
        setTimeout(function() { notif.addClass('d-none'); }, 4000);
      },
      error: function() {
        let notif = $('#restartNotif');
        notif.removeClass('d-none alert-success').addClass('alert-danger').text('Gagal menghubungi server!');
        setTimeout(function() { notif.addClass('d-none'); }, 4000);
      }
    });
  });
});
</script>
</body>
</html>
